{
  "manifest_version": 3,
  "name": "历史记录透镜",
  "description": "管理、清理和找回 Chrome 本地浏览历史。",
  "version": "1.0.0",
  "minimum_chrome_version": "116",
  "permissions": ["history", "storage", "tabs", "sidePanel", "favicon"],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "打开历史记录透镜",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "index.html"
  }
}
