{
  "manifest_version": 3,
  "name": "History Record Lens - AI History Search | One-Click Cleanup",
  "short_name": "History Lens",
  "description": "Find Chrome browsing history with AI, maintain website lists, and clean local history with one click.",
  "version": "1.0.2",
  "minimum_chrome_version": "116",
  "permissions": ["history", "storage", "tabs", "sidePanel", "favicon"],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open History Record Lens",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "index.html"
  }
}
