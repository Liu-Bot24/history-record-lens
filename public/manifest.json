{
  "manifest_version": 3,
  "name": "历史记录透镜 - AI 查找浏览历史 | 一键清理记录",
  "short_name": "历史透镜",
  "description": "用大模型查找 Chrome 浏览历史，维护网站清单并一键清理本地浏览记录。",
  "version": "1.0.2",
  "minimum_chrome_version": "116",
  "permissions": ["history", "storage", "tabs", "sidePanel", "favicon"],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "打开历史记录透镜",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "index.html"
  }
}
